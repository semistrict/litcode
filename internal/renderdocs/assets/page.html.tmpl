<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <style>
{{ .ChromaCSS }}
    :root {
      color-scheme: dark;
      --bg: #11151c;
      --panel: #171d26;
      --text: #edf2f7;
      --muted: #9aa7b8;
      --accent: #7bdff2;
      --accent-strong: #9bf6ff;
      --border: #2b3645;
      --border-strong: rgba(123, 223, 242, 0.28);
      --code-bg: #202938;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background:
        radial-gradient(circle at top left, rgba(123, 223, 242, 0.16), transparent 28rem),
        linear-gradient(180deg, #151b24 0%, var(--bg) 100%);
      color: var(--text);
      font-family: Georgia, "Iowan Old Style", "Palatino Linotype", serif;
      line-height: 1.65;
    }
    main {
      max-width: 54rem;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }
    article {
      background: rgba(23, 29, 38, 0.92);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 2rem;
      box-shadow: 0 18px 48px rgba(0, 0, 0, 0.28);
      backdrop-filter: blur(8px);
    }
    h1, h2, h3 {
      font-family: "Avenir Next Condensed", "Franklin Gothic Medium", sans-serif;
      line-height: 1.1;
      letter-spacing: 0.02em;
    }
    h1 { font-size: clamp(2.5rem, 5vw, 3.6rem); margin-top: 0; }
    h2 { font-size: 1.8rem; margin-top: 2.4rem; }
    h3 { font-size: 1.25rem; margin-top: 1.8rem; }
    p, li { font-size: 1.05rem; }
    a { color: var(--accent); }
    code {
      font-family: "SFMono-Regular", Menlo, Consolas, monospace;
      background: var(--code-bg);
      padding: 0.1rem 0.3rem;
      border-radius: 0.3rem;
    }
    pre {
      overflow-x: auto;
      padding: 1rem;
      border-radius: 12px;
      background: #1e1f24;
      color: #f7f4ef;
    }
    pre.tok-chroma {
      background: #1e1f24;
      color: #f7f4ef;
    }
    pre code {
      background: transparent;
      padding: 0;
      border-radius: 0;
      color: inherit;
    }
    .litcode-block {
      margin: 1.6rem 0;
    }
    .litcode-block > pre,
    .litcode-block > .mermaid {
      margin: 0;
    }
    .litcode-block-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      padding: 0.8rem 0.95rem;
      border: 1px solid var(--border-strong);
      border-bottom: 0;
      border-radius: 14px 14px 0 0;
      background:
        linear-gradient(180deg, rgba(123, 223, 242, 0.12), rgba(123, 223, 242, 0.03)),
        rgba(23, 29, 38, 0.86);
    }
    .litcode-block-toolbar + pre,
    .litcode-block-toolbar + .mermaid {
      border-top-left-radius: 0;
      border-top-right-radius: 0;
    }
    .litcode-block-label {
      min-width: 0;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.55rem 0.8rem;
      font-family: "Avenir Next", "Helvetica Neue", sans-serif;
      letter-spacing: 0.02em;
    }
    .litcode-block-file {
      font-family: "SFMono-Regular", Menlo, Consolas, monospace;
      font-size: 0.85rem;
      color: var(--text);
      overflow-wrap: anywhere;
    }
    .litcode-block-lines {
      font-size: 0.78rem;
      color: var(--muted);
      text-transform: uppercase;
    }
    .litcode-block-actions {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .litcode-link {
      border: 1px solid rgba(123, 223, 242, 0.28);
      border-radius: 999px;
      padding: 0.38rem 0.75rem;
      background: rgba(123, 223, 242, 0.1);
      color: var(--accent-strong);
      font-family: "Avenir Next", "Helvetica Neue", sans-serif;
      font-size: 0.82rem;
      line-height: 1;
      letter-spacing: 0.02em;
      text-decoration: none;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background-color 180ms ease,
        color 180ms ease;
    }
    .litcode-link:hover,
    .litcode-link:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(155, 246, 255, 0.5);
      background: rgba(123, 223, 242, 0.16);
      color: #c9fbff;
      outline: none;
    }
    .mermaid {
      margin: 1.5rem 0;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--panel);
    }
    @media (max-width: 700px) {
      article { padding: 1.25rem; }
      main { padding: 1rem 0.75rem 3rem; }
      .litcode-block-toolbar {
        align-items: flex-start;
        flex-direction: column;
      }
      .litcode-block-actions {
        justify-content: flex-start;
      }
    }
  </style>
</head>
<body>
  <main>
    <article>
{{ .Body }}
    </article>
  </main>
  <script type="module">
    import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
    mermaid.initialize({ startOnLoad: true, theme: "dark" });
  </script>
</body>
</html>
